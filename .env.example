# Fitness Dashboard — data-source credentials (EXAMPLE)
#
# Copy to `.env` and fill in real values. The real `.env` is gitignored AND
# dockerignored — it must NEVER be committed or baked into the image.
# Keep the real file mode 600.
#
# ----- Garmin Connect (python-garminconnect) -----
GARMIN_EMAIL=you@example.com
GARMIN_PASSWORD=changeme
# Where the auth token cache is persisted (so we don't re-login every run).
GARMIN_TOKENSTORE=.garmin_tokens

# ----- Strava (official OAuth API) -----
# Create an app at https://www.strava.com/settings/api to get these.
STRAVA_CLIENT_ID=
STRAVA_CLIENT_SECRET=
STRAVA_REFRESH_TOKEN=

# ----- Sync behaviour -----
# How many days of history to backfill on the first run (subsequent runs are incremental).
SYNC_BACKFILL_DAYS=120
